DATABASE_URI=postgres://twowo:twowo_dev@localhost:5432/twowo_dev
PAYLOAD_SECRET=replace-with-output-of-openssl-rand-hex-32
SYNC_SECRET=shared-secret-for-internal-sync-endpoints
FEED_SECRET=shared-secret-for-syndication-feed-consumers
SITE_URL=https://www.twowheelobsession.com.au
# Yamaha OEM Parts Finder — EPC Online integration (paid subscription)
EPC_DEALER_ID=
EPC_PRODUCT_KEY_YAMAHA=324d31df-d5ab-4449-85a7-43e5a97c3e28
# Email — SendGrid via SMTP relay (https://sendgrid.com — free tier 100/day)
# Username on the SMTP transport is hard-coded as "apikey"; password is
# the SendGrid API key value below. EMAIL_FROM_ADDRESS must be a
# verified Single Sender or domain in SendGrid before sending will work.
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=enquiries@twowheelobsession.com.au
EMAIL_FROM_NAME=Two Wheel Obsession
ENQUIRY_NOTIFY_EMAIL=enquiries@twowheelobsession.com.au
# Parts orders (Yamaha Parts Australia) get emailed here for manual fulfilment.
PARTS_ORDER_NOTIFY_EMAIL=info@twowheelobsession.com.au

# PayPal — Yamaha Parts Australia checkout. Two app credentials are
# needed (sandbox for dev, live for prod); pick which environment to
# hit via PAYPAL_ENV. Create both apps under the same TWO PayPal
# Business account at developer.paypal.com.
# Leave these as the placeholder while developing locally — the server
# guard in lib/paypal/client.ts will refuse to make API calls and any
# real checkout attempt fails fast with a clear error.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=PLACEHOLDER_GET_FROM_NIKKIE
PAYPAL_CLIENT_SECRET=PLACEHOLDER_GET_FROM_NIKKIE
# Client-side mirror of PAYPAL_CLIENT_ID (must be public so the PayPal
# JS SDK can render the Smart Buttons in the browser). Same VALUE as
# PAYPAL_CLIENT_ID — only the prefix differs.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=PLACEHOLDER_GET_FROM_NIKKIE

